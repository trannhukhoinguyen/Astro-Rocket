---
/**
 * Comments — provider dispatcher
 *
 * Renders the configured comments provider at the bottom of a blog post.
 * Only the selected provider's component (and therefore only its client-side
 * script) is included in the page output.
 *
 * The enabled/per-post gating happens in `BlogLayout.astro`; this component is
 * only mounted when comments should show. Pick the provider and fill in its
 * settings in `site.config.ts` → articleFeatures.comments.
 */
import siteConfig from '@/config/site.config';
import CommentsGiscus from './CommentsGiscus.astro';
import CommentsCusdis from './CommentsCusdis.astro';
import CommentsArtalk from './CommentsArtalk.astro';

const provider = siteConfig.articleFeatures?.comments?.provider ?? 'giscus';
---

{
  provider === 'cusdis' ? (
    <CommentsCusdis />
  ) : provider === 'artalk' ? (
    <CommentsArtalk />
  ) : (
    <CommentsGiscus />
  )
}
