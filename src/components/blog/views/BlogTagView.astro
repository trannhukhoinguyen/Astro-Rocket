---
/**
 * BlogTagView — a tag archive page.
 *
 * Shared body for the default-locale route (`/blog/tag/<tag>`) and the
 * locale-prefixed route (`/<locale>/blog/tag/<tag>`). The matching posts and
 * the visible tag cloud are resolved in each route's `getStaticPaths` and
 * passed in; URLs are built locale-aware via `lib/blog`.
 */
import type { CollectionEntry } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import TagList from '@/components/blog/TagList.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { t, defaultLocale } from '@/i18n';
import { getBlogBaseUrl, getPostUrl } from '@/lib/blog';

interface Props {
  /** Locale whose posts this archive renders. Defaults to the site default. */
  locale?: string;
  /** The active tag (display form). */
  tag: string;
  /** Posts carrying this tag, in the locale. */
  posts: CollectionEntry<'blog'>[];
  /** Tags to render in the cloud (always includes the active tag). */
  visibleTags: string[];
}

const { locale = defaultLocale, tag, posts, visibleTags } = Astro.props;

const blogHref = getBlogBaseUrl(locale);
const countKey = posts.length === 1 ? 'blog.tagCountOne' : 'blog.tagCountOther';
---

<PageLayout
  title={t('blog.tagMetaTitle', locale, { tag })}
  description={t('blog.tagMetaDescription', locale, { tag })}
  eagerReveal
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="tag" size="sm" />
      {t('blog.tagBadge', locale)}
    </Badge>

    <h1
      slot="title"
      class="!text-4xl sm:!text-5xl md:!text-6xl lg:!text-7xl break-words [overflow-wrap:anywhere]"
    >#{tag}</h1>

    <p slot="description">
      {t(countKey, locale, { count: posts.length, tag })}
    </p>
  </Hero>

  <section class="bg-background-secondary py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4" data-reveal>
        <a
          href={blogHref}
          class="group inline-flex items-center gap-2 rounded-lg border border-brand-500/40 bg-transparent px-4 py-2 text-sm font-medium text-brand-700 dark:text-brand-400 hover:border-brand-500/80 hover:bg-brand-500/10 transition-colors"
        >
          <Icon name="arrow-left" size="sm" />
          {t('blog.allPosts', locale)}
        </a>

        {visibleTags.length > 0 && (
          <TagList tags={visibleTags} active={tag} locale={locale} class="justify-center" />
        )}
      </div>

      {posts.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post, index) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              href={getPostUrl(post.id, locale)}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              author={post.data.author}
              image={post.data.image}
              svgSlug={post.data.svgSlug}
              body={post.body}
              revealDelay={index % 3}
              eager={index === 0}
            />
          ))}
        </div>
      ) : (
        <div class="py-16 text-center">
          <div class="bg-background mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full">
            <Icon name="file-text" size="lg" class="text-foreground-muted" />
          </div>
          <p class="text-foreground-muted text-lg">{t('blog.tagEmpty', locale)}</p>
          <div class="mt-6">
            <Button href={blogHref} variant="brand-outline" size="sm">
              <Icon name="arrow-left" size="sm" />
              {t('blog.tagBackToAll', locale)}
            </Button>
          </div>
        </div>
      )}
    </div>
  </section>
</PageLayout>
