---
/**
 * Horizontal list of tag chips that link to project tag archive pages
 * (`/projects/tag/<slug>`). Pure HTML — no JS. Mirrors the blog `TagList`
 * so blog and project tags look and behave identically.
 */
import { defaultLocale } from '@/i18n';
import { getProjectTagUrl } from '@/lib/projects';

interface Props {
  tags: string[];
  /** Highlight this tag (used on the tag archive page). */
  active?: string;
  /**
   * Locale the links belong to. Default-locale links stay at
   * `/projects/tag/...`; other locales are prefixed (`/<locale>/projects/tag/...`).
   */
  locale?: string;
  /** Optional class extension. */
  class?: string;
}

const { tags, active, locale = defaultLocale, class: extraClass } = Astro.props;
---

{tags.length > 0 && (
  <ul class:list={['flex flex-wrap items-center gap-2', extraClass]} aria-label="Browse by tag">
    {tags.map((tag) => {
      const isActive = active === tag;
      return (
        <li>
          <a
            href={getProjectTagUrl(tag, locale)}
            class:list={[
              'inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium transition-colors',
              isActive
                ? 'border-brand-500 bg-brand-500 text-white'
                : 'border-brand-500/40 bg-transparent text-brand-700 dark:text-brand-400 hover:border-brand-500/80',
            ]}
            aria-current={isActive ? 'page' : undefined}
          >
            #{tag}
          </a>
        </li>
      );
    })}
  </ul>
)}
