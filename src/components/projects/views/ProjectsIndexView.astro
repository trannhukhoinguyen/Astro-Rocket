---
/**
 * ProjectsIndexView — the projects landing page (page 1).
 *
 * Shared body for the default-locale route (`/projects`) and the
 * locale-prefixed route (`/<locale>/projects`). All project/pagination/tag URLs
 * are built locale-aware via the helpers in `lib/projects`, so rendering with
 * the default locale produces exactly the same markup the route did before this
 * was extracted.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import ProjectCard from '@/components/projects/ProjectCard.astro';
import ProjectTagList from '@/components/projects/ProjectTagList.astro';
import Pagination from '@/components/blog/Pagination.astro';
import { t, defaultLocale, localizedPath } from '@/i18n';
import {
  collectTopProjectTags,
  getProjectsPageUrl,
  getVisibleProjects,
  PROJECT_TAG_CLOUD_LIMIT,
  PROJECTS_PER_PAGE,
} from '@/lib/projects';

interface Props {
  /** Locale whose projects this index renders. Defaults to the site default. */
  locale?: string;
}

const { locale = defaultLocale } = Astro.props;

const projects = await getVisibleProjects(locale);
const topTags = collectTopProjectTags(projects, PROJECT_TAG_CLOUD_LIMIT);

// Page 1 lives here at /projects; /projects/page/2..N handle the rest.
const totalPages = Math.max(1, Math.ceil(projects.length / PROJECTS_PER_PAGE));
const pageProjects = projects.slice(0, PROJECTS_PER_PAGE);

const contactUrl = localizedPath('/contact', locale);
const aboutUrl = localizedPath('/about', locale);
---

<PageLayout
  title={t('projects.metaTitle', locale)}
  description={t('projects.metaDescription', locale)}
  eagerReveal
  footerBackground="secondary"
>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="layers" size="sm" />
      {t('projects.heroBadge', locale)}
    </Badge>

    <h1 slot="title">{t('projects.title', locale)}</h1>

    <p slot="description">
      {t('projects.heroDescription', locale)}
    </p>
  </Hero>

  <!-- All projects -->
  {projects.length > 0 && (
    <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
      <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">

        {topTags.length > 0 && (
          <div class="flex flex-col items-center gap-4" data-reveal>
            <ProjectTagList tags={topTags} locale={locale} class="justify-center" />
          </div>
        )}

        <div class="grid gap-6 md:grid-cols-2">
          {pageProjects.map((project, i) => (
            <ProjectCard project={project} index={i} locale={locale} />
          ))}
        </div>

        <Pagination
          currentPage={1}
          totalPages={totalPages}
          href={(p) => getProjectsPageUrl(p, locale)}
        />
      </div>
    </section>
  )}

 <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <!-- Mobile: flat section, no card -->
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">{t('projects.ctaBadge', locale)}</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        {t('projects.ctaHeading', locale)}
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        {t('projects.ctaLead', locale)}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href={contactUrl} class="cta-btn-brand">
          {t('projects.ctaPrimary', locale)}
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="brand-outline" href={aboutUrl}>
          {t('projects.ctaSecondary', locale)}
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <!-- Desktop: contained LetterGlitch band with glass card -->
    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        {t('projects.ctaHeading', locale)}
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        {t('projects.ctaLead', locale)}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href={contactUrl} class="hero-btn-brand">
          {t('projects.ctaPrimary', locale)}
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href={aboutUrl}>
          {t('projects.ctaSecondary', locale)}
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</PageLayout>
