---
/**
 * ProjectsTagView — a project tag archive page.
 *
 * Shared body for the default-locale route (`/projects/tag/<tag>`) and the
 * locale-prefixed route (`/<locale>/projects/tag/<tag>`). The matching projects
 * and the visible tag cloud are resolved in each route's `getStaticPaths` and
 * passed in; URLs are built locale-aware via `lib/projects`.
 */
import type { CollectionEntry } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import ProjectCard from '@/components/projects/ProjectCard.astro';
import ProjectTagList from '@/components/projects/ProjectTagList.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { t, defaultLocale } from '@/i18n';
import { getProjectsBaseUrl } from '@/lib/projects';

interface Props {
  /** Locale whose projects this archive renders. Defaults to the site default. */
  locale?: string;
  /** The active tag (display form). */
  tag: string;
  /** Projects carrying this tag, in the locale. */
  projects: CollectionEntry<'projects'>[];
  /** Tags to render in the cloud (always includes the active tag). */
  visibleTags: string[];
}

const { locale = defaultLocale, tag, projects, visibleTags } = Astro.props;

const projectsHref = getProjectsBaseUrl(locale);
const countKey = projects.length === 1 ? 'projects.tagCountOne' : 'projects.tagCountOther';
---

<PageLayout
  title={t('projects.tagMetaTitle', locale, { tag })}
  description={t('projects.tagMetaDescription', locale, { tag })}
  eagerReveal
  footerBackground="secondary"
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="tag" size="sm" />
      {t('projects.tagBadge', locale)}
    </Badge>

    <h1
      slot="title"
      class="!text-4xl sm:!text-5xl md:!text-6xl lg:!text-7xl break-words [overflow-wrap:anywhere]"
    >#{tag}</h1>

    <p slot="description">
      {t(countKey, locale, { count: projects.length, tag })}
    </p>
  </Hero>

  <section class="bg-background-secondary py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4" data-reveal>
        <a
          href={projectsHref}
          class="group inline-flex items-center gap-2 rounded-lg border border-brand-500/40 bg-transparent px-4 py-2 text-sm font-medium text-brand-700 dark:text-brand-400 hover:border-brand-500/80 hover:bg-brand-500/10 transition-colors"
        >
          <Icon name="arrow-left" size="sm" />
          {t('projects.allProjects', locale)}
        </a>

        {visibleTags.length > 0 && (
          <ProjectTagList tags={visibleTags} active={tag} locale={locale} class="justify-center" />
        )}
      </div>

      {projects.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2">
          {projects.map((project, i) => (
            <ProjectCard project={project} index={i} locale={locale} />
          ))}
        </div>
      ) : (
        <div class="py-16 text-center">
          <div class="bg-background mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full">
            <Icon name="layers" size="lg" class="text-foreground-muted" />
          </div>
          <p class="text-foreground-muted text-lg">{t('projects.tagEmpty', locale)}</p>
          <div class="mt-6">
            <Button href={projectsHref} variant="brand-outline" size="sm">
              <Icon name="arrow-left" size="sm" />
              {t('projects.tagBackToAll', locale)}
            </Button>
          </div>
        </div>
      )}
    </div>
  </section>
</PageLayout>
