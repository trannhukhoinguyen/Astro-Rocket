---
import ProjectsPageView from '@/components/projects/views/ProjectsPageView.astro';
import { defaultLocale } from '@/i18n';
import { getProjectPageCount } from '@/lib/projects';

// Paginated projects index for the default locale (page 2..N). Page 1 lives at
// `/projects`. Additional locales are served by
// `src/pages/[locale]/projects/page/[page].astro`.
export async function getStaticPaths() {
  const totalPages = await getProjectPageCount(defaultLocale);

  const pages: { params: { page: string }; props: { page: number; totalPages: number } }[] = [];
  for (let page = 2; page <= totalPages; page++) {
    pages.push({ params: { page: String(page) }, props: { page, totalPages } });
  }
  return pages;
}

const { page, totalPages } = Astro.props;
---

<ProjectsPageView locale={defaultLocale} page={page} totalPages={totalPages} />
