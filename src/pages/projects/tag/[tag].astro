---
import ProjectsTagView from '@/components/projects/views/ProjectsTagView.astro';
import { defaultLocale } from '@/i18n';
import {
  PROJECT_TAG_CLOUD_LIMIT,
  collectProjectTags,
  collectTopProjectTags,
  getVisibleProjects,
  tagToSlug,
} from '@/lib/projects';

// Tag archive pages for the default locale. Additional locales are served by
// `src/pages/[locale]/projects/tag/[tag].astro`, which renders the same view.
export async function getStaticPaths() {
  const projects = await getVisibleProjects(defaultLocale);
  const tags = collectProjectTags(projects);
  const topTags = collectTopProjectTags(projects, PROJECT_TAG_CLOUD_LIMIT);

  return tags.map((tag) => {
    const projectsForTag = projects.filter((p) => p.data.tags.includes(tag));
    // Keep the active tag in the cloud even when it's not popular enough to
    // make the top N, so the page always acknowledges the tag the user picked.
    const visibleTags = topTags.includes(tag)
      ? topTags
      : [tag, ...topTags.slice(0, PROJECT_TAG_CLOUD_LIMIT - 1)];
    return {
      params: { tag: tagToSlug(tag) },
      props: { tag, projects: projectsForTag, visibleTags },
    };
  });
}

const { tag, projects, visibleTags } = Astro.props;
---

<ProjectsTagView locale={defaultLocale} tag={tag} projects={projects} visibleTags={visibleTags} />
