---
/**
 * Project tag archive
 * URL: /projects/tag/<slug>
 */
import PageLayout from '@/layouts/PageLayout.astro';
import ProjectCard from '@/components/projects/ProjectCard.astro';
import ProjectTagList from '@/components/projects/ProjectTagList.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import {
  collectProjectTags,
  collectTopProjectTags,
  getVisibleProjects,
  tagToSlug,
} from '@/lib/projects';

export async function getStaticPaths() {
  // Inlined because Astro's getStaticPaths runs in its own isolated
  // scope and can't see frontmatter-level consts.
  const TAG_CLOUD_LIMIT = 10;

  const projects = await getVisibleProjects();
  const tags = collectProjectTags(projects);
  const topTags = collectTopProjectTags(projects, TAG_CLOUD_LIMIT);

  return tags.map((tag) => {
    const projectsForTag = projects.filter((p) => p.data.tags.includes(tag));
    // Keep the active tag in the cloud even when it's not popular enough to
    // make the top N, so the page always acknowledges the tag the user picked.
    const visibleTags = topTags.includes(tag)
      ? topTags
      : [tag, ...topTags.slice(0, TAG_CLOUD_LIMIT - 1)];
    return {
      params: { tag: tagToSlug(tag) },
      props: { tag, projects: projectsForTag, visibleTags },
    };
  });
}

const { tag, projects, visibleTags } = Astro.props;
---

<PageLayout
  title={`#${tag} — Projects`}
  description={`Projects tagged "${tag}".`}
  eagerReveal
  footerBackground="secondary"
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="tag" size="sm" />
      Tag
    </Badge>

    <h1
      slot="title"
      class="!text-4xl sm:!text-5xl md:!text-6xl lg:!text-7xl break-words [overflow-wrap:anywhere]"
    >#{tag}</h1>

    <p slot="description">
      {projects.length} project{projects.length === 1 ? '' : 's'} tagged "{tag}".
    </p>
  </Hero>

  <section class="bg-background-secondary py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4" data-reveal>
        <a
          href="/projects"
          class="group inline-flex items-center gap-2 rounded-lg border border-border-strong bg-transparent px-4 py-2 text-sm font-medium text-foreground-muted hover:border-brand-500 hover:text-brand-500 transition-colors"
        >
          <Icon name="arrow-left" size="sm" />
          All projects
        </a>

        {visibleTags.length > 0 && (
          <ProjectTagList tags={visibleTags} active={tag} class="justify-center" />
        )}
      </div>

      {projects.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2">
          {projects.map((project, i) => (
            <ProjectCard project={project} index={i} />
          ))}
        </div>
      ) : (
        <div class="py-16 text-center">
          <div class="bg-background mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full">
            <Icon name="layers" size="lg" class="text-foreground-muted" />
          </div>
          <p class="text-foreground-muted text-lg">No projects found for this tag.</p>
          <div class="mt-6">
            <Button href="/projects" variant="outline" size="sm">
              <Icon name="arrow-left" size="sm" />
              Back to all projects
            </Button>
          </div>
        </div>
      )}
    </div>
  </section>
</PageLayout>
