---
import BlogPageView from '@/components/blog/views/BlogPageView.astro';
import { defaultLocale } from '@/i18n';
import { getBlogPageCount } from '@/lib/blog';

// Paginated blog index for the default locale (page 2..N). Page 1 lives at
// `/blog`. Additional locales are served by
// `src/pages/[locale]/blog/page/[page].astro`.
export async function getStaticPaths() {
  const totalPages = await getBlogPageCount(defaultLocale);

  const pages: { params: { page: string }; props: { page: number; totalPages: number } }[] = [];
  for (let page = 2; page <= totalPages; page++) {
    pages.push({ params: { page: String(page) }, props: { page, totalPages } });
  }
  return pages;
}

const { page, totalPages } = Astro.props;
---

<BlogPageView locale={defaultLocale} page={page} totalPages={totalPages} />
