---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TypingEffect from '@/components/ui/TypingEffect.astro';
import TechStack from '@/components/landing/TechStack.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
---
<PageLayout
  title="About Astro Rocket — Astro 6 Starter Theme"
  description="Astro Rocket is a production-ready Astro 6 starter theme with 12 themes, 57+ components, built-in i18n, dark mode, and everything you need to launch fast."
  footerBackground="secondary"
>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="rocket" size="sm" />
      About
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Astro Rocket —</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">
        <TypingEffect words={["Astro 6 Starter", "Production-Ready", "12 Themes", "57+ Components", "Dark Mode", "Built-in i18n", "Zero Config SEO"]} />
      </span>
    </h1>

    <p slot="description">
      A free, production-ready Astro 6 starter theme with everything you need to build fast, modern websites — without starting from scratch.
    </p>
  </Hero>

  <!-- About the theme -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 glitch:grid-cols-2 glitch:gap-12">
        <!-- Left: text -->
        <div class="flex flex-col justify-center gap-4 sm:items-center sm:text-center glitch:items-start glitch:text-left" data-reveal data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 sm:items-center glitch:items-start">
            <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">Free & Open Source</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-balance">
              A solid foundation for any project
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
            Astro Rocket is a production-ready starter theme built on Astro 6. It ships with a full component library, 12 hand-crafted themes, dark mode, built-in i18n, and a blog — so you can focus on building your project, not the boilerplate.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
            It's free, MIT licensed, and listed on the official Astro themes directory. Clone it, customise it, and ship something you're proud of.
          </p>
        </div>
        <!-- Right: theme facts card -->
        <div class="flex flex-col h-full" data-reveal data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="flex-1 flex flex-col justify-center">
            <div class="grid grid-cols-2 sm:grid-cols-3 glitch:grid-cols-2 gap-x-6 gap-y-8">
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="rocket" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Astro 6</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Built on the latest Astro release.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="layout" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">12 themes</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Switch themes with one line.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="code-2" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">57+ components</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Composable, production-ready.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="sparkles" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Dark mode</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Built in, no extra setup needed.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="award" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Built-in i18n</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Multi-language support out of the box.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="zap" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Zero config SEO</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Structured data & meta tags included.
                  </p>
                </div>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Design Principles</Badge>
          <h2 class="font-display text-4xl font-bold text-foreground">
            Built with intention
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Every decision in Astro Rocket — from component structure to default config — is driven by the same three principles.
        </p>
      </div>
      <div class="grid gap-6 sm:gap-8 sm:grid-cols-3">
        <Card hover data-reveal>
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Performance First</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Zero JavaScript by default. Every component is optimised for speed, Core Web Vitals, and lean output.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="award" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Developer Experience</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                TypeScript throughout, sensible defaults, and a component library you can drop straight into any page.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="rocket" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Modern from the Ground Up</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Astro 6, Tailwind CSS 4, and a clean architecture that's easy to extend and maintain.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <TechStack
    badge="Tools & Tech"
    title="The Stack"
    description="The technologies powering Astro Rocket — chosen for performance, great developer experience, and long-term reliability."
    background="secondary"
  />

  <!-- FAQ -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Good to know</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Frequently asked questions
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Everything you need to know before getting started.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Card 1: About Astro -->
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="1">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="rocket" size="md" />
            </div>
            <h3 class="font-display text-base font-semibold text-foreground">About Astro</h3>
          </div>
          <div class="w-full">
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                What is Astro?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Astro is a modern web framework built for content-driven sites. It ships zero JavaScript by default — only sending what the page actually needs. The result is fast load times, excellent Core Web Vitals scores, and lean, maintainable code.
              </div>
            </details>
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Why build with Astro?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Astro is the right tool for content-heavy sites: minimal JavaScript, clean HTML, great SEO out of the box, and a developer experience that stays out of your way. It's lean, purposeful, and built to last.
              </div>
            </details>
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                What can I build with Astro Rocket?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Portfolios, business sites, marketing pages, blogs, documentation sites — any content-driven project. Astro Rocket gives you the structure, components, and defaults to hit the ground running.
              </div>
            </details>
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Is Astro Rocket listed on the official Astro themes directory?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Yes. <a href="https://astro.build/themes/details/astro-rocket/" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-brand-500 hover:text-brand-400 transition-colors">Astro Rocket</a> is listed on the official Astro themes directory as a free, production-ready theme.
              </div>
            </details>
            <details class="border-b border-border last:border-0" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Will Astro Rocket keep up with new Astro releases?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Yes. Astro Rocket is actively maintained and updated to track new Astro releases. Follow along on the blog or watch the GitHub repository for updates.
              </div>
            </details>
          </div>
        </Card>

        <!-- Card 2: Using the theme -->
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="2">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="code-2" size="md" />
            </div>
            <h3 class="font-display text-base font-semibold text-foreground">Using the theme</h3>
          </div>
          <div class="w-full">
            <details class="border-b border-border" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Is it free to use?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Yes, completely free. Astro Rocket is MIT licensed — use it for personal and commercial projects, no attribution required.
              </div>
            </details>
            <details class="border-b border-border" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                How do I switch themes?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Change a single line in your config. Astro Rocket ships with 12 hand-crafted colour themes — swap between them instantly without touching a line of CSS.
              </div>
            </details>
            <details class="border-b border-border" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Does it support TypeScript?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Yes, TypeScript is used throughout. All components, configs, and utilities are fully typed.
              </div>
            </details>
            <details class="border-b border-border" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                How do I add my own language for i18n?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Astro Rocket's i18n is config-driven. Add your locale to the i18n config file, create a matching translation file, and the routing and UI adapt automatically.
              </div>
            </details>
            <details class="border-b border-border last:border-0" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Where do I report bugs or suggest features?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Open an issue or start a discussion on the <a href="https://github.com/hansmartensdev/astro-rocket" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-brand-500 hover:text-brand-400 transition-colors">GitHub repository</a>. Contributions and feedback are always welcome.
              </div>
            </details>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Open Source -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-8 sm:gap-10 glitch:grid-cols-2 glitch:items-center">
        <!-- Text -->
        <div class="flex flex-col gap-4 sm:items-center sm:text-center glitch:items-start glitch:justify-center glitch:text-left" data-reveal data-reveal-ease="smooth">
          <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">Open Source</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Built in the open
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
            Astro Rocket is free, open source, and MIT licensed. Browse the source, open issues, submit PRs, or just clone it and build something great.
          </p>
          <Button variant="outline" size="lg" href="https://github.com/hansmartensdev/astro-rocket" target="_blank" rel="noopener noreferrer" class="self-start sm:self-center glitch:self-start mt-2">
            View on GitHub
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>

        <!-- Info card -->
        <div class="flex flex-col h-full" data-reveal data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="flex-1 flex flex-col justify-center gap-6">
            <div class="flex flex-col gap-2">
              <h3 class="text-base font-semibold text-foreground">Made by Hans Martens</h3>
              <p class="text-sm text-foreground-muted leading-relaxed">
                Astro Rocket was designed and built by <a href="https://hansmartens.dev" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-brand-500 hover:text-brand-400 transition-colors">Hans Martens</a> — a web designer and developer who uses it as the foundation for client projects.
              </p>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-base font-semibold text-foreground">MIT License</h3>
              <p class="text-sm text-foreground-muted leading-relaxed">
                Free to use in personal and commercial projects. No attribution required, though a star on GitHub is always appreciated.
              </p>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-base font-semibold text-foreground">Actively maintained</h3>
              <p class="text-sm text-foreground-muted leading-relaxed">
                The theme is kept up to date with new Astro releases and regularly improved based on community feedback.
              </p>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <!-- Mobile: flat section, no card -->
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Get started</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Ready to build?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Clone Astro Rocket, pick a theme, and launch your next project in minutes.
      </p>
      <Button size="lg" href="https://github.com/hansmartensdev/astro-rocket" target="_blank" rel="noopener noreferrer" class="cta-btn-brand">
        Get Started
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>

    <!-- Desktop: contained LetterGlitch band with glass card -->
    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Ready to build?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Clone Astro Rocket, pick a theme, and launch your next project in minutes.
      </p>
      <Button size="lg" href="https://github.com/hansmartensdev/astro-rocket" target="_blank" rel="noopener noreferrer" class="hero-btn-brand">
        Get Started
        <Icon name="arrow-right" size="sm" />
      </Button>
    </LetterGlitchBand>
  </section>
</PageLayout>

<style>
  details[open] > summary .faq-icon {
    transform: rotate(180deg);
  }
</style>
