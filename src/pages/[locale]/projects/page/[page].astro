---
import ProjectsPageView from '@/components/projects/views/ProjectsPageView.astro';
import { getProjectPageCount, getSecondaryLocales } from '@/lib/projects';

// Locale-prefixed paginated projects index (`/<locale>/projects/page/N`, N >= 2).
// Page 1 lives at `/<locale>/projects`. Emits nothing when i18n is off.
export async function getStaticPaths() {
  const paths: {
    params: { locale: string; page: string };
    props: { page: number; totalPages: number };
  }[] = [];

  for (const locale of getSecondaryLocales()) {
    const totalPages = await getProjectPageCount(locale);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { locale, page: String(page) },
        props: { page, totalPages },
      });
    }
  }

  return paths;
}

const { locale } = Astro.params;
const { page, totalPages } = Astro.props;
---

<ProjectsPageView locale={locale} page={page} totalPages={totalPages} />
