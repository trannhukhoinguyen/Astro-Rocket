---
import ProjectsTagView from '@/components/projects/views/ProjectsTagView.astro';
import {
  PROJECT_TAG_CLOUD_LIMIT,
  collectProjectTags,
  collectTopProjectTags,
  getVisibleProjects,
  getSecondaryLocales,
  tagToSlug,
} from '@/lib/projects';

// Locale-prefixed tag archives (`/<locale>/projects/tag/<tag>`). One page per
// (non-default locale × tag that exists in that locale). Emits nothing when
// i18n is off.
export async function getStaticPaths() {
  const paths: {
    params: { locale: string; tag: string };
    props: {
      tag: string;
      projects: Awaited<ReturnType<typeof getVisibleProjects>>;
      visibleTags: string[];
    };
  }[] = [];

  for (const locale of getSecondaryLocales()) {
    const projects = await getVisibleProjects(locale);
    const tags = collectProjectTags(projects);
    const topTags = collectTopProjectTags(projects, PROJECT_TAG_CLOUD_LIMIT);

    for (const tag of tags) {
      const projectsForTag = projects.filter((p) => p.data.tags.includes(tag));
      const visibleTags = topTags.includes(tag)
        ? topTags
        : [tag, ...topTags.slice(0, PROJECT_TAG_CLOUD_LIMIT - 1)];
      paths.push({
        params: { locale, tag: tagToSlug(tag) },
        props: { tag, projects: projectsForTag, visibleTags },
      });
    }
  }

  return paths;
}

const { locale } = Astro.params;
const { tag, projects, visibleTags } = Astro.props;
---

<ProjectsTagView locale={locale} tag={tag} projects={projects} visibleTags={visibleTags} />
