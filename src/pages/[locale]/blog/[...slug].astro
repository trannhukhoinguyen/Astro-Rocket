---
import BlogLayout from '@/layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';
import { getPostSlug, getSecondaryLocales } from '@/lib/blog';
import PostLink from '@/components/blog/PostLink.astro';

// Locale-prefixed blog posts (`/<locale>/blog/<slug>`). One page per
// (non-default locale × published post in that locale). Emits nothing when
// i18n is off. The default-locale posts are served by `src/pages/blog/
// [...slug].astro`, which also runs the build-time content-integrity guards
// across every locale, so they are not repeated here.
export async function getStaticPaths() {
  const paths: {
    params: { locale: string; slug: string };
    props: { post: Awaited<ReturnType<typeof getCollection<'blog'>>>[number] };
  }[] = [];

  for (const locale of getSecondaryLocales()) {
    const posts = await getCollection('blog', ({ data }) => {
      return data.locale === locale && (import.meta.env.PROD ? data.draft !== true : true);
    });
    for (const post of posts) {
      paths.push({
        params: { locale, slug: getPostSlug(post.id, locale) },
        props: { post },
      });
    }
  }

  return paths;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  publishedAt={post.data.publishedAt}
  updatedAt={post.data.updatedAt}
  author={post.data.author}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  svgSlug={post.data.svgSlug}
  tags={post.data.tags}
  slug={post.id}
  uid={post.data.uid}
  faqs={post.data.faqs}
  headings={headings}
  toc={post.data.toc}
  comments={post.data.comments}
>
  <Content components={{ PostLink }} />
</BlogLayout>
