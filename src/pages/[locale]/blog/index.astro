---
import BlogIndexView from '@/components/blog/views/BlogIndexView.astro';
import { getSecondaryLocales } from '@/lib/blog';

// Locale-prefixed blog landing pages (`/<locale>/blog`). One page per
// non-default locale. Emits nothing when i18n is off or only one locale is
// configured, so single-locale builds are unchanged. A locale with no posts
// yet still gets a page (the view shows the empty state) so the
// LanguageSwitcher never lands on a 404.
export function getStaticPaths() {
  return getSecondaryLocales().map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
---

<BlogIndexView locale={locale} />
