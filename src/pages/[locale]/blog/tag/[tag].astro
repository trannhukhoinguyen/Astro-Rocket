---
import BlogTagView from '@/components/blog/views/BlogTagView.astro';
import {
  collectTags,
  collectTopTags,
  getPublishedPosts,
  getSecondaryLocales,
  tagToSlug,
} from '@/lib/blog';

// Locale-prefixed tag archives (`/<locale>/blog/tag/<tag>`). One page per
// (non-default locale × tag that exists in that locale). Emits nothing when
// i18n is off.
export async function getStaticPaths() {
  // Inlined because Astro's getStaticPaths runs in its own isolated scope.
  const TAG_CLOUD_LIMIT = 10;

  const paths: {
    params: { locale: string; tag: string };
    props: {
      tag: string;
      posts: Awaited<ReturnType<typeof getPublishedPosts>>;
      visibleTags: string[];
    };
  }[] = [];

  for (const locale of getSecondaryLocales()) {
    const posts = await getPublishedPosts(locale);
    const tags = collectTags(posts);
    const topTags = collectTopTags(posts, TAG_CLOUD_LIMIT);

    for (const tag of tags) {
      const postsForTag = posts.filter((p) => p.data.tags.includes(tag));
      const visibleTags = topTags.includes(tag)
        ? topTags
        : [tag, ...topTags.slice(0, TAG_CLOUD_LIMIT - 1)];
      paths.push({
        params: { locale, tag: tagToSlug(tag) },
        props: { tag, posts: postsForTag, visibleTags },
      });
    }
  }

  return paths;
}

const { locale } = Astro.params;
const { tag, posts, visibleTags } = Astro.props;
---

<BlogTagView locale={locale} tag={tag} posts={posts} visibleTags={visibleTags} />
