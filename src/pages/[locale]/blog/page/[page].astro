---
import BlogPageView from '@/components/blog/views/BlogPageView.astro';
import { getBlogPageCount, getSecondaryLocales } from '@/lib/blog';

// Locale-prefixed paginated blog index (`/<locale>/blog/page/N`, N >= 2).
// Page 1 lives at `/<locale>/blog`. Emits nothing when i18n is off.
export async function getStaticPaths() {
  const paths: {
    params: { locale: string; page: string };
    props: { page: number; totalPages: number };
  }[] = [];

  for (const locale of getSecondaryLocales()) {
    const totalPages = await getBlogPageCount(locale);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { locale, page: String(page) },
        props: { page, totalPages },
      });
    }
  }

  return paths;
}

const { locale } = Astro.params;
const { page, totalPages } = Astro.props;
---

<BlogPageView locale={locale} page={page} totalPages={totalPages} />
